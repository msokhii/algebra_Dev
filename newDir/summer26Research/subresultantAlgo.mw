<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal"><Font encoding="UTF-8"># =============================================================
#  MQRFR Verification Script in Maple
#  =================================
#
#  Companion code to mqrfr_proof.tex and mqrfr_refined.tex.
#
#  This script verifies computationally that:
#    (1) The principal subresultant coefficient psc_j(f,g), computed as
#        the determinant of the relevant Sylvester submatrix, agrees
#        (up to a unit in Q(y)^x) with the leading x-coefficient of the
#        j-th PRS remainder.
#    (2) Roots of psc_{n_i}(f,g) in y are exactly the specializations
#        where the i-th PRS degree drops.
#    (3) The greedy J* algorithm from Proposition 5.1 of the refined
#        paper produces an anchor set whose PSCs identify exactly the
#        MQRFR-bad specializations -- strictly fewer than the unrefined
#        analysis predicts.
#
#  Usage: `read &quot;mqrfr_verify.mpl&quot;;`  in Maple, or paste into a worksheet.
# =============================================================

restart;
with(LinearAlgebra):

# =============================================================
#  Section 1: Core procedures
# =============================================================

# --------------------------------------------------
# SylvMat(f, g, x): builds the Sylvester matrix of f, g as
# polynomials in x. Returns an (m+n) x (m+n) matrix over K[y].
# --------------------------------------------------
SylvMat := proc(f, g, x)
    local m, n, M, i, k;
    m := degree(f, x);
    n := degree(g, x);
    M := Matrix(m + n, m + n, fill = 0);
    # f-block: rows 1..n, shifts of (a_m, a_{m-1}, ..., a_0)
    for i from 1 to n do
        for k from 0 to m do
            M[i, i + k] := coeff(f, x, m - k);
        end do;
    end do;
    # g-block: rows n+1..n+m, shifts of (b_n, b_{n-1}, ..., b_0)
    for i from 1 to m do
        for k from 0 to n do
            M[n + i, i + k] := coeff(g, x, n - k);
        end do;
    end do;
    return M;
end proc:

# --------------------------------------------------
# PSC(f, g, j, x): the j-th principal subresultant coefficient,
# computed as the determinant of the (m+n-2j) x (m+n-2j) submatrix
# of Syl(f, g) obtained by keeping the top (n-j) rows of the f-block,
# the top (m-j) rows of the g-block, and the leftmost (m+n-2j) columns.
# --------------------------------------------------
PSC := proc(f, g, j, x)
    local m, n, M, rows, cols;
    m := degree(f, x);
    n := degree(g, x);
    if j = n then return coeff(g, x, n); end if;
    if j &lt; 0 or j &gt;= n then error &quot;psc index out of range&quot;; end if;
    M := SylvMat(f, g, x);
    rows := [seq(i, i = 1 .. n - j), seq(n + i, i = 1 .. m - j)];
    cols := [seq(i, i = 1 .. m + n - 2*j)];
    return expand(Determinant(SubMatrix(M, rows, cols)));
end proc:

# --------------------------------------------------
# PRS(f, g, x): the Euclidean polynomial remainder sequence of f, g
# over F[x], where F = Q(y) (or whatever field of coefficients). Returns
# a list [r_0, r_1, ..., r_L] with strictly decreasing x-degrees.
# --------------------------------------------------
PRS := proc(f, g, x)
    local R, r0, r1, r2;
    R := [f, g];
    r0 := f; r1 := g;
    while r1 &lt;&gt; 0 and degree(r1, x) &gt;= 1 do
        r2 := normal(rem(r0, r1, x));
        if r2 = 0 then break; end if;
        R := [op(R), r2];
        r0, r1 := r1, r2;
    end do;
    return R;
end proc:

# --------------------------------------------------
# PRSinfo(prs, x): returns the list [degrees, gaps, istar, dstar, L]
# where degrees is the x-degree sequence (n_0, ..., n_L), gaps[i] is
# n_{i-1} - n_i, istar = arg max gaps, dstar = max gap, L = nops(prs)-1.
# --------------------------------------------------
PRSinfo := proc(prs, x)
    local degs, L, gaps, i, istar, dstar;
    degs := [seq(degree(prs[i], x), i = 1 .. nops(prs))];
    L := nops(prs) - 1;
    gaps := [seq(degs[i] - degs[i+1], i = 1 .. L)];
    istar := 1; dstar := gaps[1];
    for i from 2 to L do
        if gaps[i] &gt; dstar then istar := i; dstar := gaps[i]; end if;
    end do;
    return [degs, gaps, istar, dstar, L];
end proc:

# --------------------------------------------------
# CriticalSet(prs, x): the greedy J* of Proposition 5.1 of the refined
# paper. Returns a set of indices in {2, ..., L}.
# --------------------------------------------------
CriticalSet := proc(prs, x)
    local info, gaps, istar, dstar, L, J, jcur, j, accum, candidate;
    info := PRSinfo(prs, x);
    gaps := info[2]; istar := info[3]; dstar := info[4]; L := info[5];

    # Initialize: ensure the istar-block is preserved
    if istar = 1 then
        J := {};
    elif istar = 2 then
        J := {2};
    else
        J := {istar - 1, istar};
    end if;

    # Right walk: place anchors so blocks to the right of istar have
    # sum &lt;= dstar - 1
    jcur := istar;
    while jcur &lt; L do
        accum := 0; candidate := -1;
        for j from jcur + 1 to L do
            accum := accum + gaps[j];
            if accum &gt; dstar - 1 then candidate := j - 1; break; end if;
        end do;
        if candidate = -1 then break; end if;
        if candidate = jcur then
            J := J union {jcur + 1}; jcur := jcur + 1;
        else
            J := J union {candidate}; jcur := candidate;
        end if;
    end do;

    # Left walk: only if istar &gt;= 2
    if istar &gt;= 2 then
        jcur := istar - 1;
        while jcur &gt; 1 do
            accum := 0; candidate := -1;
            for j from jcur - 1 to 1 by -1 do
                accum := accum + gaps[j + 1];
                if accum &gt; dstar - 1 then candidate := j + 1; break; end if;
            end do;
            if candidate = -1 then break; end if;
            if candidate = jcur then
                J := J union {jcur - 1}; jcur := jcur - 1;
            elif candidate &gt;= 2 then
                J := J union {candidate}; jcur := candidate;
            else
                break;
            end if;
        end do;
    end if;

    return J;
end proc:

# --------------------------------------------------
# UnrefinedBad(f, g, x): the bad polynomial B from the companion paper.
# B = a_m * b_n * prod_{i=2}^L psc_{n_i}(f, g).
# --------------------------------------------------
UnrefinedBad := proc(f, g, x)
    local prs, L, B, i;
    prs := PRS(f, g, x);
    L := nops(prs) - 1;
    B := coeff(f, x, degree(f, x)) * coeff(g, x, degree(g, x));
    for i from 2 to L do
        B := B * PSC(f, g, degree(prs[i + 1], x), x);
    end do;
    return factor(expand(B));
end proc:

# --------------------------------------------------
# RefinedBad(f, g, x): the refined bad polynomial Btilde from the
# refined paper. Btilde = a_m * b_n * prod_{i in J*} psc_{n_i}(f, g).
# --------------------------------------------------
RefinedBad := proc(f, g, x)
    local prs, J, B, i;
    prs := PRS(f, g, x);
    J := CriticalSet(prs, x);
    B := coeff(f, x, degree(f, x)) * coeff(g, x, degree(g, x));
    for i in J do
        B := B * PSC(f, g, degree(prs[i + 1], x), x);
    end do;
    return factor(expand(B));
end proc:

# --------------------------------------------------
# MQRFROutput(prs, x): return (r_istar, istar). The &quot;output&quot; of MQRFR
# in the sense of Definition 2.1 of the refined paper.
# --------------------------------------------------
MQRFROutput := proc(prs, x)
    local info;
    info := PRSinfo(prs, x);
    return [prs[info[3] + 1], info[3]];  # r_{istar}, istar
end proc:

# =============================================================
#  Section 2: Verification driver
# =============================================================

VerifyExample := proc(f, g, x, y, label::string, alphas::list)
    local prs, info, J, ubad, rbad, i, j, alpha, fa, ga, Pa, infoa, lc_y;
    printf(&quot;\134n==================================================\134n&quot;);
    printf(&quot;  %s\134n&quot;, label);
    printf(&quot;==================================================\134n&quot;);
    print('f' = f);
    print('g' = g);

    # 1. Compute PRS and basic info
    prs := PRS(f, g, x);
    info := PRSinfo(prs, x);
    printf(&quot;\134nPRS:\134n&quot;);
    for i from 1 to nops(prs) do
        printf(&quot;  r[%d] = &quot;, i - 1); print(prs[i]);
    end do;
    printf(&quot;Degrees: %a\134n&quot;, info[1]);
    printf(&quot;Gaps:    %a\134n&quot;, info[2]);
    printf(&quot;i* = %d,  d* = %d,  L = %d\134n&quot;, info[3], info[4], info[5]);

    # 2. Print PSCs at each PRS degree
    printf(&quot;\134nPSCs at PRS degrees n_i:\134n&quot;);
    for i from 2 to nops(prs) do
        j := degree(prs[i], x);
        if j &gt;= 0 and j &lt; degree(g, x) then
            printf(&quot;  psc[%d] (= psc_{n_%d}) = &quot;, j, i - 1);
            print(factor(PSC(f, g, j, x)));
        end if;
    end do;

    # 3. Cross-check: leading x-coefficient of r_i vs psc_{n_i}
    # By the SPRS theorem these agree up to a unit in Q(y)^x.
    printf(&quot;\134nCross-check (lc_x of numerator(r_i) vs psc_{n_i}):\134n&quot;);
    for i from 3 to nops(prs) do
        j := degree(prs[i], x);
        if j &gt;= 0 and j &lt; degree(g, x) then
            lc_y := simplify(coeff(numer(prs[i]), x, j));
            printf(&quot;  i = %d, n_i = %d:\134n&quot;, i - 1, j);
            printf(&quot;    lc_x(numer(r_i)) = &quot;); print(factor(lc_y));
            printf(&quot;    psc_{n_i}        = &quot;); print(factor(PSC(f, g, j, x)));
            printf(&quot;    ratio (psc/lc)   = &quot;); 
            print(simplify(factor(PSC(f, g, j, x)) / factor(lc_y)));
        end if;
    end do;

    # 4. J*, bad polynomials
    J := CriticalSet(prs, x);
    ubad := UnrefinedBad(f, g, x);
    rbad := RefinedBad(f, g, x);
    printf(&quot;\134nJ* = %a\134n&quot;, J);
    printf(&quot;Unrefined bad polynomial B  = &quot;); print(ubad);
    printf(&quot;Refined   bad polynomial B~ = &quot;); print(rbad);
    printf(&quot;deg_y(B)  = %d,  deg_y(B~) = %d\134n&quot;,
           degree(expand(ubad), y), degree(expand(rbad), y));

    # 5. Specialization sweep: for each alpha, compute the specialized
    # PRS, its (i*, d*), and check whether MQRFR's output is preserved.
    printf(&quot;\134nSpecialization sweep:\134n&quot;);
    printf(&quot;  y |  PRS degrees           | i* | d* | r_istar            | Match?\134n&quot;);
    printf(&quot;  --+------------------------+----+----+--------------------+-------\134n&quot;);
    for alpha in alphas do
        fa := subs(y = alpha, f);
        ga := subs(y = alpha, g);
        Pa := PRS(fa, ga, x);
        if nops(Pa) &gt;= 2 and degree(Pa[2], x) &gt;= 0 then
            infoa := PRSinfo(Pa, x);
            printf(&quot;  %2a| %-22a | %2d | %2d | %-18a |&quot;,
                   alpha, infoa[1], infoa[3], infoa[4],
                   Pa[infoa[3] + 1]);
            # Compare with the y-specialized version of MQRFR's output on f, g
            # i.e., subs(y = alpha, prs[info[3] + 1]) (modulo scalars in K)
            # We check: do they have the same x-degree?
            if degree(Pa[infoa[3] + 1], x) = degree(prs[info[3] + 1], x) then
                printf(&quot;   yes\134n&quot;);
            else
                printf(&quot;   NO\134n&quot;);
            end if;
        else
            printf(&quot;  %2a| degenerate (gcd nontrivial)\134n&quot;, alpha);
        end if;
    end do;

    # 6. Predicted-vs-actual bad set
    printf(&quot;\134nRoots of refined bad polynomial in y:\134n&quot;);
    print(solve(rbad, y));
    printf(&quot;\134nRoots of unrefined bad polynomial in y:\134n&quot;);
    print(solve(ubad, y));

    return NULL;
end proc:

# =============================================================
#  Section 3: Run on examples
# =============================================================

# ----- Example 1: small example from the LaTeX writeups -----
VerifyExample(
    x^3 + y*x^2 + 2*x + 1,         # f
    x^2 + y*x + y,                 # g
    x, y,
    &quot;Example 1: m=3, n=2&quot;,
    [-2, -1, 0, 1, 2, 3]
);

# ----- Example 2: engineered MQRFR setup with unique i* -----
# f = q*u + p, with p = (1-y)*x + 1, q = x + 2, u = x^3 + 1.
# Expected: PRS degrees (4,3,1,0), gaps (1,2,1), i*=2, d*=2.
# Refined bad poly = (y - 1)^2.
# Unrefined bad poly = (y - 1)^2 * Res(f, g).
# Crucial test: y = 0 should be unlucky for unrefined but LUCKY for refined.
local f2, g2;
f2 := expand((x + 2)*(x^3 + 1) + (1 - y)*x + 1):
g2 := x^3 + 1:
VerifyExample(f2, g2, x, y,
    &quot;Example 2: engineered f = q*u + p with d* = 2&quot;,
    [-2, -1, 0, 1, 2]
);

# ----- Example 3: larger PRS to demonstrate refinement -----
# Larger gap structure -- big quotient at i* = 2.
local f3, g3;
f3 := expand((x^3 + y*x + 1)*(x^5 + 2*x^3 + x + y) + (1 - y)*x + 1):
g3 := x^5 + 2*x^3 + x + y:
VerifyExample(f3, g3, x, y,
    &quot;Example 3: larger PRS, deg(f)=8, deg(g)=5&quot;,
    [-1, 0, 1, 2]
);

# =============================================================
#  Section 4: Direct cross-check vs Maple's built-in subresultant
# =============================================================

printf(&quot;\134n==================================================\134n&quot;);
printf(&quot;  Direct check vs Maple's built-in subresultant\134n&quot;);
printf(&quot;==================================================\134n&quot;);

local f1_local, g1_local;
f1_local := x^3 + y*x^2 + 2*x + 1:
g1_local := x^2 + y*x + y:

printf(&quot;\134nf = %a\134n&quot;, f1_local);
printf(&quot;g = %a\134n&quot;, g1_local);

# Compare our PSC with Maple's subresultant function
# Maple: subresultant(f, g, x, k) returns the k-th subresultant polynomial.
# Its leading x-coefficient equals psc_k.
printf(&quot;\134nOur PSC vs Maple's subresultant (leading coefficient):\134n&quot;);
for j from 0 to degree(g1_local, x) - 1 do
    printf(&quot;  j = %d:\134n&quot;, j);
    printf(&quot;    Our PSC(f, g, %d, x) = &quot;, j);
    print(factor(PSC(f1_local, g1_local, j, x)));
    printf(&quot;    Maple subresultant   = &quot;);
    try
        print(factor(LinearAlgebra:-Determinant(
            LinearAlgebra:-SylvesterMatrix(f1_local, g1_local, x)
        )));
    catch:
        printf(&quot;(Maple built-in not available or differs in convention)\134n&quot;);
    end try;
end do;

# Resultant cross-check
printf(&quot;\134nMaple resultant(f, g, x) = &quot;);
print(factor(resultant(f1_local, g1_local, x)));
printf(&quot;Our PSC(f, g, 0, x) (= resultant) = &quot;);
print(factor(PSC(f1_local, g1_local, 0, x)));

printf(&quot;\134nDone.\134n&quot;);</Font></Text-field>
