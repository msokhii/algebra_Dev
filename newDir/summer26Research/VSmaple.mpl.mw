<Group labelreference="L2" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal"><Font encoding="UTF-8">VSMAPLE := proc(v::{Vector,list},m::{Vector,list},p::prime,shift::integer:=0)
local t,i,j,M,x,a,q,r,s,temp;
   t := numelems(v);
   if numelems(m) &lt;&gt; t then        error &quot;v and m must be the same size&quot;;    fi;
   (* printf(&quot;Maple Vandermonde solver: t=%d  p=%d\134n&quot;,t,p); *)
   M := 1;
   for r in m do 
       M := Expand(M*(x-r)) mod p; 
   od;
   a := Vector(t);
   for j to t do
       q := Quo(M,x-m[j],x) mod p;
       r := 1/Eval(q,x=m[j]) mod p;
       s := 0;
       for i to t do            s := s + v[i]*coeff(q,x,i-1);        od;
       a[j] := r*s mod p;
       if shift=0 then            next        fi;
       r := 1/m[j] mod p;
       r := r &amp;^ shift mod p;
       a[j] := r*a[j] mod p;
   od;
   if type(v,list) then        a := convert(a,list);    fi;
   return a;
end:</Font></Text-field>
</Input>
</Group>
<Group hide-input="false" labelreference="L3" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">p := 1153:
alpha := numtheory[primroot](p):
e := [11,45,61,72,95,116,201,234,301,310,411,454]:
t := nops(e):
m := [seq(alpha &amp;^ e[i] mod p, i=1..t)]:
c := rand(1000):
f := add(c()*x^e[i], i=1..t);
v := [seq(Eval(f,x=modp(alpha &amp;^ i,p)) mod p, i=0..t-1)]:
a := VSMAPLE(v,m,p);
add(a[i]*x^e[i],i=1..t) - f;</Text-field>
</Input>
