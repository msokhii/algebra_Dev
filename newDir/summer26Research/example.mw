<Group hide-input="false" labelreference="L22" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">p := 101:n := -73*y-4+(-83*y-10)*x+(62*y-82)*x^2+(80*y-44)*x^3+(71*y-17)*x^4:n;</Text-field>
</Input>
<Output><Text-field style="2D Output" layout="Maple Output"><Equation executable="false" style="2D Output" display="">LC5JInlHNiIhI3QhIiUiIiIqJiwmRiMhIyQpISM1RidGJ0kieEdGJEYnRicqJiwmRiMiI2khIyMpRidGJ0YsIiIjRicqJiwmRiMiIyEpISNXRidGJ0YsIiIkRicqJiwmRiMiI3IhIzxGJ0YnRiwiIiVGJw==</Equation></Text-field>
</Output>
</Group>
<Group hide-input="false" labelreference="L23" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">(* Case 1: Degree bounds are known. We make use of Wang's algorithm i.e. m=deg(N)+deg(D)+1=5. *)m := degree(n,x)+2:xArr := Array(1..m):for i from 1 to m do    xArr[i] := i:od:xArr;</Text-field>
</Input>
<Output><Text-field style="2D Output" layout="Maple Output"><Equation executable="false" style="2D Output" display="">LV9JLFR5cGVzZXR0aW5nRzYkJSpwcm90ZWN0ZWRHSShfc3lzbGliRzYiSSxtcHJpbnRzbGFzaEdGKDYkNyMtSSdSVEFCTEVHRig2JSI1J3pRQ0tfIilbJCpvJC1JJ1ZFQ1RPUkdGKDYjNygtSSNtbkc2JEYmL0krbW9kdWxlbmFtZUdGKEYkNiNRIjFGKC1GNTYjUSIyRigtRjU2I1EiM0YoLUY1NiNRIjRGKC1GNTYjUSI1RigtRjU2I1EiNkYoSSZBcnJheUdGJjcjLUZKNiMvSSQlaWRHRihGLw==</Equation></Text-field>
</Output>
</Group>
<Group hide-input="false" labelreference="L24" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">yArr := Array(1..m):for i from 1 to m do    yArr[i] := Eval(n,x=xArr[i]) mod p:od:yArr;</Text-field>
</Input>
<Output><Text-field style="2D Output" layout="Maple Output"><Equation executable="false" style="2D Output" display=""></Equation></Text-field>
</Output>
</Group>
<Group hide-input="false" labelreference="L28" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">P := Interp(xArr,yArr,x) mod p:P;</Text-field>
</Input>
<Output><Text-field style="2D Output" layout="Maple Output"><Equation executable="false" style="2D Output" display="">LC5JInlHNiIiI0ciIygqIiIiKiYsJkYjIiM9IiMiKkYnRidJInhHRiRGJ0YnKiYsJkYjIiNpIiM+RidGJ0YsIiIjRicqJiwmRiMiIyEpIiNkRidGJ0YsIiIkRicqJiwmRiMiI3IiIyUpRidGJ0YsIiIlRic=</Equation></Text-field>
