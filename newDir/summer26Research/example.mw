<Group hide-input="false" labelreference="L34" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">M := Expand(mul(x-xArr[i],i=1..m)) mod p:M;</Text-field>
</Input>
<Output><Text-field style="2D Output" layout="Maple Output"><Equation executable="false" style="2D Output" display="">LDAqJEkieEc2IiIiJyIiIiokRiQiIiYiIyEpKiRGJCIiJSIjdSokRiQiIiQiI3QqJEYkIiIjIiIpRiQiI2EiIzhGJw==</Equation></Text-field>
</Output>
</Group>
<Group hide-input="false" labelreference="L35" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal"><Font encoding="UTF-8">(* Extended Euclidean Algorithm *)m_EEA := proc(M::polynom,P::polynom)
local r,t,k,LCr,u,q,prs,allRoots,R,rootOnly,i:

prs := table():
allRoots := []:
r[0] := M: r[1] := P:
t[0] := 0: t[1] := 1:
k := 1:
while r[k] &lt;&gt; 0 do
    LCr := numer(lcoeff(r[k],x)):
    #printf(&quot;Degree(r[%d],x) = %d and LC(r[%d]) = %a\134n&quot;,k, degree(r[k],x), k, LCr):    R := Roots(LCr) mod p:
    rootOnly := [seq(R[i][1],i=1..nops(R))]:
    #printf(&quot;Roots = %a\134n&quot;,rootOnly):
    prs[k] := degree(r[k],x):
    allRoots := [op(allRoots),op(rootOnly)]:    u := 1/lcoeff(r[k],x) mod p:
    r[k] := collect(u*r[k],x,NN):
    t[k] := collect(u*t[k],x,NN):
    q := collect(Quo(r[k-1],r[k],x) mod p,x,NN):    print(degree(q,x)):
    print(Step(k), r[k]/t[k], Quo(q)):
    r[k+1] := collect(r[k-1] - q*r[k], x, NN):
    t[k+1] := collect(t[k-1] - q*t[k], x, NN):    k++:od:
prs := convert(prs, list):
allRoots := convert(convert(allRoots,set),list):
return(prs,allRoots):
end proc:</Font></Text-field>
</Input>
