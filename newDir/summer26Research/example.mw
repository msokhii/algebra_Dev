<Group labelreference="L67" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">m_MQRFR := proc(M,P,x,p) 
local r,t,q,k,qMax,u,n,d:

r[0],r[1] := M,P:
t[0],t[1] := 0,1:
k := 1:
qMax := 0:
while r[k]&lt;&gt; 0 do
    u := 1/lcoeff(t[k],x) mod p:
    r[k],t[k] := u*r[k] mod p,u*t[k] mod p:
    q := Quo(r[k-1],r[k],x) mod p:
    print(Step(k),r[k]/t[k],Gcd(r[k],t[k]) mod p,Quo(q));
    if degree(q)&gt;qMax then
        qMax := degree(q):
        n := r[k]:
        d := t[k]:
    elif qMax=2 and degree(q)&gt;=qMax then
        print(n/d,r[k]/t[k]);
    fi:
    r[k+1] := Expand(r[k-1]-q*r[k]) mod p:
    t[k+1] := Expand(t[k-1]-q*t[k]) mod p:
    k++:
od;
if qMax&lt;2 then
    return FAIL:
else
    return n/d;
fi:
end proc:</Text-field>
</Input>
</Group>
