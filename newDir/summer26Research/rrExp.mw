</Input>
<Output><Text-field style="2D Output" layout="Maple Output"><Equation executable="false" style="2D Output" display="">LCgqJiIjSCIiIilJInhHNiIiIiNGJUYlKiYiI1lGJUYnRiVGJSIjV0Yl</Equation></Text-field>
</Output>
<Output><Text-field style="2D Output" layout="Maple Output"><Equation executable="false" style="2D Output" display="">LCgqJiIjSyIiIilJInhHNiIiIiNGJUYlKiYiIiZGJUYnRiVGJSIjTEYl</Equation></Text-field>
</Output>
</Group>
<Group hide-input="false" labelreference="L11" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal"><Font encoding="UTF-8">printf(&quot;GCD of num. and denom. is %d.\134n&quot;,g):
</Font></Text-field>
</Input>
<Output><Text-field style="Line Printed Output" layout="Line Printed Output">GCD of num. and denom. is 1.
</Text-field>
</Output>
</Group>
<Group labelreference="L12" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">MAKEMONIC := proc(argA::polynom,argB::polynom,argC::posint,argD::posint,p)
local n,d,g,degN,degD,LCD,invD:  

n := argA:
d := argB: 
LCD := lcoeff(d): 
if LCD&lt;&gt;1 then 
    g := Gcdex(LCD,p,x,'s','t') mod p:
    if g&lt;&gt;1 then 
        return 'FAIL':
    fi:
    invD := s:
    n := Expand(invD*n) mod p: 
    d := Expand(invD*d) mod p: 
    return (n,d): 
fi: 
return (n,d):
end proc:</Text-field>
</Input>
</Group>
<Group labelreference="L14" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">(* At this stage, we have imposed gcd(n,d)=1 and LC(d)=1 for uniqueness. *)

n,d := MAKEMONIC(n,d,degN,degD,p):</Text-field>
</Input>
</Group>
