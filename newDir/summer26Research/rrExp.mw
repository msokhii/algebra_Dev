</Input>
</Group>
<Group labelreference="L53" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">(* Since, we know the degrees beforehand, the total number of points to interpolate 
n and d would be the following: *) 

m := degN+degD:</Text-field>
</Input>
</Group>
<Group hide-input="false" labelreference="L2" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">n := x^degN+randpoly(x,coeffs=rNum,degree=degN) mod p:
d := x^degD+randpoly(x,coeffs=rNum,degree=degD) mod p:
n;
d;</Text-field>
</Input>
<Output><Text-field style="2D Output" layout="Maple Output"><Equation executable="false" style="2D Output" display="">LCgqJiIjSCIiIilJInhHNiIiIiNGJUYlKiYiI1lGJUYnRiVGJSIjV0Yl</Equation></Text-field>
</Output>
<Output><Text-field style="2D Output" layout="Maple Output"><Equation executable="false" style="2D Output" display="">LCgqJiIjSyIiIilJInhHNiIiIiNGJUYlKiYiIiZGJUYnRiVGJSIjTEYl</Equation></Text-field>
</Output>
</Group>
<Group labelreference="L4" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">g := Gcd(n,d) mod p:
<Font encoding="UTF-8">printf(&quot;GCD of num. and denom. is %d.\134n&quot;,g);</Font>
while g&lt;&gt;1 do
    n := x^degN+randpoly(x,coeffs=rNum,degree=degN) mod p:
    d := x^degD+randpoly(x,coeffs=rNum,degree=degD) mod p:
    g := Gcd(n,d) mod p:
od:
</Text-field>
</Input>
<Output><Text-field style="Line Printed Output" layout="Line Printed Output">GCD of num. and denom. is 1.
</Text-field>
</Output>
</Group>
