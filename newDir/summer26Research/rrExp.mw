<Group labelreference="L19" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">(* Generate m alpha points from S which is a large finite subset of F. *)POPX := proc(argA::posint)
local xVec,numPT,i: 

numPT := argA:
xVec := Array(0..numPT-1):

for i from 0 to numPT-1 do 
    xVec[i] := rNum(): 
od: 
return xVec:
end proc:     </Text-field>
</Input>
</Group>
