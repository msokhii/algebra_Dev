<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">p := prevprime(50):rNum := rand(p):degN := 2:degD := 2:</Text-field>
</Input>
</Group>
<Group labelreference="L53" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">(* Since, we know the degrees beforehand, the total number of points to interpolate n and d would be the following: *) m := degN+degD:</Text-field>
</Input>
</Group>
<Group hide-input="false" labelreference="L2" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">n := x^degN+randpoly(x,coeffs=rNum,degree=degN) mod p:d := x^degD+randpoly(x,coeffs=rNum,degree=degD) mod p:n;d;</Text-field>
</Input>
<Output><Text-field style="2D Output" layout="Maple Output"><Equation executable="false" style="2D Output" display="">LCgqJEkieEc2IiIiIyIjSEYkIiNZIiNXIiIi</Equation></Text-field>
</Output>
<Output><Text-field style="2D Output" layout="Maple Output"><Equation executable="false" style="2D Output" display="">LCgqJEkieEc2IiIiIyIjS0YkIiImIiNMIiIi</Equation></Text-field>
</Output>
</Group>
<Group labelreference="L4" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">g := Gcd(n,d) mod p:<Font encoding="UTF-8">printf(&quot;GCD of num. and denom. is %d.\134n&quot;,g);</Font>while g&lt;&gt;1 do    n := x^degN+randpoly(x,coeffs=rNum,degree=degN) mod p:
    d := x^degD+randpoly(x,coeffs=rNum,degree=degD) mod p:    g := Gcd(n,d) mod p:od:</Text-field>
</Input>
<Output><Text-field style="Line Printed Output" layout="Line Printed Output">GCD of num. and denom. is 1.
</Text-field>
</Output>
</Group>
<Group hide-input="false" labelreference="L50" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">n;d;</Text-field>
</Input>
<Output><Text-field style="2D Output" layout="Maple Output"><Equation executable="false" style="2D Output" display="">LCgqJEkieEc2IiIiIyIjSEYkIiNZIiNXIiIi</Equation></Text-field>
</Output>
<Output><Text-field style="2D Output" layout="Maple Output"><Equation executable="false" style="2D Output" display="">LCgqJEkieEc2IiIiIyIjS0YkIiImIiNMIiIi</Equation></Text-field>
</Output>
</Group>
<Group hide-input="false" labelreference="L11" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal"><Font encoding="UTF-8">printf(&quot;GCD of num. and denom. is %d.\134n&quot;,g):</Font></Text-field>
</Input>
<Output><Text-field style="Line Printed Output" layout="Line Printed Output">GCD of num. and denom. is 1.
</Text-field>
</Output>
</Group>
<Group labelreference="L12" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">MAKEMONIC := proc(argA::polynom,argB::polynom,argC::posint,argD::posint,p)
local n,d,g,degN,degD,LCD,invD:  

n := argA:
d := argB: 
LCD := lcoeff(d): 
if LCD&lt;&gt;1 then 
    g := Gcdex(LCD,p,x,'s','t') mod p:
    if g&lt;&gt;1 then 
        return 'FAIL':
    fi:
    invD := s:
    n := Expand(invD*n) mod p: 
    d := Expand(invD*d) mod p: 
    return (n,d): 
fi: 
return (n,d):
end proc:</Text-field>
</Input>
</Group>
<Group labelreference="L14" drawlabel="true" applyint="true" applyrational="true" applyexponent="false">
<Input><Text-field prompt="&gt; " style="Maple Input" layout="Normal">(* At this stage, we have imposed gcd(n,d)=1 and LC(d)=1 for uniqueness. *)n,d := MAKEMONIC(n,d,degN,degD,p):</Text-field>
</Input>
</Group>
